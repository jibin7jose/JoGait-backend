datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   // "clinician" | "patient" | "admin"
  password  String
  createdAt DateTime @default(now())
}

model Session {
  id           String   @id
  patientId    String
  planId       String?
  deviceId     String
  startTime    DateTime
  endTime      DateTime
  scoreSummary Json     // { overallScore: number, symmetryIndex: number }
  flags        String[]
  createdAt    DateTime @default(now())
}

model Metric {
  id         String   @id @default(uuid())
  sessionId  String
  metricType String   // "kneeAngle" | "repCount"
  value      Float
  unit       String
  timestamp  DateTime
}
